{
  "$schema": "https://vercel.com/schemas/vercel.json",
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/jobs/:jobId/events",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-transform" },
        { "key": "Connection", "value": "keep-alive" }
      ]
    }
  ]
}

