{
  "name": "aioapi",
  "version": "0.1.0",
  "description": "Turn API documentation websites (Swagger/Redoc/Docusaurus) into OpenAPI & Postman formats.",
  "license": "UNLICENSED",
  "bin": {
    "aioapi": "dist/bin/aioapi.js"
  },
  "files": [
    "dist/**",
    "prompts/**",
    "templates/**",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "aioapi": "tsx src/bin/aioapi.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "playwright": "^1.58.2",
    "postman-collection": "^5.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "tsx": "^4.19.0",
    "@types/node": "^20",
    "@types/postman-collection": "^3.5.11",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  }
}
